{
  "name": "furniture-backend",
  "version": "1.0.0",
  "description": "Node/Express + MongoDB API for furniture app",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "seed": "node src/seed.js",
    "seed:site-defaults": "node src/seedSiteDefaults.js",
    "sync-stores-maps": "node src/scripts/syncStoreMapLinks.js"
  },
  "devDependencies": {
    "nodemon": "^3.1.0"
  },
  "nodemonConfig": {
    "watch": ["src"],
    "ext": "js,json"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "mongoose": "^8.3.0",
    "multer": "^2.1.1"
  }
}
